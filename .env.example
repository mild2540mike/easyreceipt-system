APP_VERSION="1.0.0"
DATABASE_URL="sqlserver://localhost:1433;database=EasyReceiptSystem;user=sa;password=YourStrong(!)Password;encrypt=true;trustServerCertificate=true"

# Express API
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"
JWT_SECRET="replace-this-with-a-long-random-secret"
JWT_EXPIRES_IN="8h"
SESSION_COOKIE_NAME="easyreceipt_session"

# Server-only OpenAI settings for purchase receipt scanning.
OPENAI_API_KEY=""
OPENAI_RECEIPT_MODEL="gpt-5.6-sol"

# Browser-facing API URL used by the Next.js frontend.
NEXT_PUBLIC_EASYRECEIPT_API_URL="http://localhost:4000/api/v1"
